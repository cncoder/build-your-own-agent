# ── Anthropic ──────────────────────────────────────────────────────────────────
# 获取地址：https://console.anthropic.com/ → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：指定模型（默认 claude-haiku-4-5-20251001，最省钱；2024 版已 deprecated）
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：指定模型（默认 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o

# ── AWS Bedrock ────────────────────────────────────────────────────────────────
# 需要先配置 AWS credentials：aws configure
# 或设置环境变量 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
AWS_REGION=us-west-2

# 可选：指定 Bedrock 模型（默认 us.anthropic.claude-haiku-4-5-20251001；2026 Claude 4.X 系列）
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
# 注意：Bedrock 用 inference profile ID（如 us.anthropic.claude-xxx），
#       不是基础模型 ID（如 anthropic.claude-xxx）
#       两者格式不同 —— 这是血泪教训（见 lessons-learned.md）
