# lena-v0.14 环境变量示例
# 复制为 .env 并填入真实值（.env 已加入 .gitignore，不要提交真实 key）

# LLM API（生产环境选其一）
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx

# AWS（防线 2：短时凭证用，需要 IAM Role ARN）
# AWS_REGION=us-east-1
# LENA_ROLE_ARN=arn:aws:iam::123456789012:role/lena-agent-role

# 工作目录（agent 只能在此目录下操作文件）
# LENA_WORKSPACE=./workspace

# 审计日志路径
# LENA_AUDIT_LOG=./audit.jsonl

# 审批超时（秒）
# LENA_APPROVAL_TIMEOUT=300
